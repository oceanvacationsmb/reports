<title>OCEAN VACATIONS TOOLS ACCESS PAGE</title>

<style>
    body {
        margin: 0;
        font-family: Arial, sans-serif;
        background: #f5f6fa;
    }

    .container {
        display: flex;
        height: 100vh;
    }

    /* LEFT NAV */
    .sidebar {
        width: 220px;
        background: #1f2a38;
        color: #fff;
        padding: 15px;
        box-sizing: border-box;
