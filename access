        font-size: 11px;
        border-radius: 4px;
        background: #3498db;
        color: #fff;
        transition: 0.2s;
    }

    .btn:hover {
        background: #2980b9;
    }

    /* MAIN CONTENT */
    .main {
        flex: 1;
        background: #fff;
    }

    iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    /* HEADER TOP */
    .topbar {
        position: absolute;
        top: 0;
        left: 220px;
        right: 0;
        height: 50px;
        background: #ffffff;
        border-bottom: 1px solid #ddd;
        display: flex;
        align-items: center;
        padding-left: 20px;
        font-weight: bold;
        z-index: 10;
    }

    .iframe-container {
